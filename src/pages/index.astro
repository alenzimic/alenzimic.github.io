---
import { faGithub, faLinkedinIn } from "@fortawesome/free-brands-svg-icons";
import { BookOpenText, Mail, NotebookText } from "@lucide/astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import BrandIcon from "../components/BrandIcon.astro";
import profile from "../lib/profile";
import { collection, firstEntry } from "../lib/content";

const about = firstEntry(
  import.meta.glob("../content/about/*.md", { eager: true }),
);
const AboutContent = about.Component;

const education = collection(
  import.meta.glob("../content/education/*.md", { eager: true }),
);
const experience = collection(
  import.meta.glob("../content/experience/*.md", { eager: true }),
);
const leadership = collection(
  import.meta.glob("../content/leadership/*.md", { eager: true }),
);
const projects = collection(
  import.meta.glob("../content/projects/*.md", { eager: true }),
);
const publications = collection(
  import.meta.glob("../content/publications/*.md", { eager: true }),
);
const fundingAwards = collection(
  import.meta.glob("../content/funding-awards/*.md", { eager: true }),
);
const talks = collection(import.meta.glob("../content/talks/*.md", { eager: true }));
const notes = collection(import.meta.glob("../content/notes/*.md", { eager: true }));

const visiblePublications = publications.filter(
  (entry) => entry.status !== "To be submitted",
);
const articlePublications = visiblePublications.filter(
  (entry) => entry.status === "Published",
);
const reviewPublications = visiblePublications.filter(
  (entry) => entry.status !== "Published",
);
const serviceEntries = leadership.filter((entry) =>
  ["01-icips", "02-igem-committee"].includes(entry.slug),
);
const [featuredExperience, ...otherExperience] = experience;
const getPublicationLinkText = (entry: { status?: string }) =>
  entry.status === "Published" ? "Read paper notes" : "Read review notes";
const contactHref = `mailto:${profile.email}?subject=${encodeURIComponent(
  "Portfolio contact",
)}&body=${encodeURIComponent(
  "Hi Alen,\n\nI saw your portfolio and wanted to get in touch about ",
)}`;
---

<BaseLayout
  title={`${profile.fullName} | Computational Biology Portfolio`}
  description={`${profile.fullName} portfolio for computational biology, plant science, bioinformatics, and environmental biotechnology. Also searched as ${profile.alternateNames.join(" or ")}.`}
>
  <header class="site-header site-header-nav-only">
    <nav class="nav" aria-label="Primary navigation">
      <a href="#about">About</a>
      <a href="#experience">Experience</a>
      <a href="#publications">Publications</a>
      <a href="#projects">Projects</a>
      <a href="#training">Training</a>
      <a href="#recognition">Recognition</a>
      <a href="#service">Service</a>
      <a href="#notes">Notes</a>
      <a href="#contact">Talk</a>
    </nav>
  </header>

  <main id="top">
    <section class="hero section-shell" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">Computational biology / plant science / bioinformatics</p>
        <h1 id="hero-title">{profile.fullName}</h1>
        <p class="name-variants">{profile.alternateNames.join(" / ")}</p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button button-primary" href={profile.cvUrl}>Curriculum Vitae</a>
          <a class="button button-secondary" href={contactHref}>Get in touch</a>
          <a class="text-link" href="#publications">Publications</a>
        </div>
      </div>
      <figure class="hero-portrait" aria-label="Portrait photo">
        <img src={profile.portraitImage} alt="" loading="eager" />
      </figure>
    </section>

    <section id="about" class="section-shell section-block about-grid" aria-labelledby="about-title">
      <div>
        <p class="section-kicker">About</p>
        <h2 id="about-title">Background</h2>
      </div>
      <div class="about-content-stack">
        <div class="prose">
          <AboutContent />
        </div>
      </div>
    </section>

    <section id="experience" class="section-shell section-block" aria-labelledby="experience-title">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Experience</p>
          <h2 id="experience-title">Current and recent work</h2>
        </div>
        <p>{profile.location}</p>
      </div>
      <div class="object-board">
        {
          featuredExperience ? (
            <article class="feature-card">
              <div class="feature-card-header">
                <p class="card-meta">{featuredExperience.date}</p>
                <h3>{featuredExperience.title}</h3>
                {featuredExperience.subtitle ? <p class="subtitle">{featuredExperience.subtitle}</p> : null}
              </div>
              <div class="feature-card-body">
                <p class="card-meta">Current focus</p>
                <p>{featuredExperience.summary}</p>
              </div>
              {featuredExperience.tags?.length ? (
                <ul class="tag-list" aria-label={`${featuredExperience.title} tags`}>
                  {featuredExperience.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              ) : null}
            </article>
          ) : null
        }
        <div class="object-list" aria-label="Recent research experience">
          {
            otherExperience.map((entry) => (
              <article class="object-row">
                <div>
                  <p class="card-meta">{entry.date}</p>
                  <h3>{entry.title}</h3>
                  {entry.subtitle ? <p class="subtitle">{entry.subtitle}</p> : null}
                </div>
                <p>{entry.summary}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="publications" class="section-block publication-band" aria-labelledby="publications-title">
      <div class="section-shell">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Publications</p>
            <h2 id="publications-title">Articles and reviews</h2>
          </div>
          <a class="text-link" href={profile.cvUrl}>Full CV</a>
        </div>

        <div class="publication-showcase">
          <section class="article-gallery" aria-labelledby="articles-title">
            <div class="publication-panel-header gallery-heading">
              <div>
                <p class="section-kicker">Articles</p>
                <h3 id="articles-title">Published articles</h3>
              </div>
              <p>{articlePublications.length} papers</p>
            </div>
            <div class="article-mosaic">
              {
                articlePublications.map((entry, index) => (
                  <a
                    class={`article-tile ${index === 0 ? "article-tile-featured" : ""}`}
                    href={`/publications/${entry.slug}/`}
                    aria-label={`${entry.title}. ${getPublicationLinkText(entry)}`}
                    title={getPublicationLinkText(entry)}
                  >
                    <span class="publication-card-main">
                      <span class="publication-card-meta">{entry.date}</span>
                      <strong>{entry.title}</strong>
                      <span class="publication-journal">{entry.journal}</span>
                    </span>
                    <span class="publication-card-summary">
                      <span class="publication-summary">{entry.summary}</span>
                      <span class="icon-action" aria-hidden="true">
                        <BookOpenText size={17} stroke-width={1.8} />
                      </span>
                    </span>
                  </a>
                ))
              }
            </div>
          </section>

          <section class="review-gallery" aria-labelledby="reviews-title">
            <div class="publication-panel-header">
              <div>
                <p class="section-kicker">Reviews</p>
                <h3 id="reviews-title">Forthcoming reviews</h3>
              </div>
              <p>{reviewPublications.length} reviews</p>
            </div>
            <div class="review-mosaic">
              {
                reviewPublications.map((entry) => (
                  <a
                    class="review-tile"
                    href={`/publications/${entry.slug}/`}
                    aria-label={`${entry.title}. ${getPublicationLinkText(entry)}`}
                    title={getPublicationLinkText(entry)}
                  >
                    <span class="publication-card-main">
                      <span class="publication-card-meta">{entry.date}</span>
                      <strong>{entry.title}</strong>
                      <span class="publication-journal">{entry.journal}</span>
                    </span>
                    <span class="publication-card-summary">
                      <span class="publication-summary">{entry.summary}</span>
                      <span class="icon-action" aria-hidden="true">
                        <BookOpenText size={17} stroke-width={1.8} />
                      </span>
                    </span>
                  </a>
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </section>

    <section id="projects" class="section-shell section-block" aria-labelledby="projects-title">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Projects</p>
          <h2 id="projects-title">Code and research builds</h2>
        </div>
        <a class="text-link" href={profile.githubUrl}>GitHub</a>
      </div>
      <div class="project-grid">
        {
          projects.map((entry) => {
            return (
              <article class="item-card project-card">
                <p class="card-meta">{entry.date}</p>
                <h3>{entry.title}</h3>
                <p class="subtitle">{entry.subtitle}</p>
                <p>{entry.summary}</p>
                {entry.tags?.length ? (
                  <ul class="tag-list">
                    {entry.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                ) : null}
                {entry.href ? (
                  <a
                    class="icon-link"
                    href={entry.href}
                    aria-label={`Open ${entry.title} repository`}
                    title="Open repository"
                  >
                    <BrandIcon icon={faGithub} size={18} />
                  </a>
                ) : null}
              </article>
            );
          })
        }
      </div>
    </section>

    <section id="training" class="section-block" aria-labelledby="education-title">
      <div class="section-shell two-column">
        <div>
          <p class="section-kicker">Education</p>
          <h2 id="education-title">Training</h2>
        </div>
        <div class="card-stack">
          {
            education.map((entry) => {
              const EntryContent = entry.Component;
              return (
                <article class="item-card">
                  <p class="card-meta">{entry.date}</p>
                  <h3>{entry.title}</h3>
                  {entry.subtitle ? <p class="subtitle">{entry.subtitle}</p> : null}
                  <div class="prose compact">
                    <EntryContent />
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </section>

    <section id="recognition" class="section-shell section-block" aria-labelledby="recognition-title">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Recognition</p>
          <h2 id="recognition-title">Funding, honors, and talks</h2>
        </div>
        <p>Selected support, awards, presentations, and public science.</p>
      </div>
      <div class="recognition-grid" aria-label="Funding, honors, talks, and media links">
        <section class="recognition-group" aria-labelledby="funding-title">
          <div class="recognition-group-header">
            <p class="section-kicker">Funding & honors</p>
            <h3 id="funding-title">Support and awards</h3>
          </div>
          <div class="recognition-list">
            {
              fundingAwards.map((entry) => (
                <a class="recognition-item" href={entry.href}>
                  <span class="recognition-date">{entry.date}</span>
                  <span>
                    <strong>{entry.title}</strong>
                    <span>{entry.summary}</span>
                  </span>
                </a>
              ))
            }
          </div>
        </section>
        <section class="recognition-group" aria-labelledby="talks-title">
          <div class="recognition-group-header">
            <p class="section-kicker">Talks & media</p>
            <h3 id="talks-title">Public science</h3>
          </div>
          <div class="recognition-list">
            {
              talks.map((entry) => (
                <a class="recognition-item" href={entry.href}>
                  <span class="recognition-date">{entry.date}</span>
                  <span>
                    <strong>{entry.title}</strong>
                    <span>{entry.summary}</span>
                  </span>
                </a>
              ))
            }
          </div>
        </section>
      </div>
    </section>

    <section id="service" class="section-shell section-block compact-section service-section" aria-labelledby="service-title">
      <div class="service-compact">
        <div class="service-intro">
          <p class="section-kicker">Community</p>
          <h2 id="service-title">Scientific service</h2>
          <p>Selected roles in training, synthetic biology, and student leadership.</p>
        </div>
        <div class="service-card-grid" aria-label="Scientific service and outreach">
          {
            serviceEntries.map((entry) => (
              entry.href ? (
                <a class="service-card" href={entry.href}>
                  <span class="service-card-main">
                    <span class="card-meta">{entry.date}</span>
                    <strong>{entry.title}</strong>
                  </span>
                  <span class="service-card-summary">
                    <span>{entry.summary}</span>
                  </span>
                </a>
              ) : (
                <article class="service-card">
                  <span class="service-card-main">
                    <span class="card-meta">{entry.date}</span>
                    <strong>{entry.title}</strong>
                  </span>
                  <span class="service-card-summary">
                    <span>{entry.summary}</span>
                  </span>
                </article>
              )
            ))
          }
        </div>
      </div>
    </section>

    <section id="notes" class="section-shell section-block compact-section" aria-labelledby="notes-title">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Notes</p>
          <h2 id="notes-title">Field notes and short writing</h2>
        </div>
        <p>A small blog-style space for updates when there is something worth writing down.</p>
      </div>
      <div class="notes-list">
        {
          notes.map((entry) => (
            <a
              class="note-row"
              href={`/notes/${entry.slug}/`}
              aria-label={`${entry.title}. Read note`}
              title="Read note"
            >
              <span class="card-meta">{entry.date}</span>
              <strong>{entry.title}</strong>
              <span>{entry.summary}</span>
              <span class="icon-action" aria-hidden="true">
                <NotebookText size={17} stroke-width={1.8} />
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section id="contact" class="contact-section" aria-labelledby="contact-title">
      <div class="section-shell contact-grid">
        <div>
          <p class="section-kicker">Contact</p>
          <h2 id="contact-title">Open to talk</h2>
        </div>
        <div class="contact-actions">
          <a class="icon-button" href={contactHref} aria-label="Send a note" title="Send a note">
            <Mail size={18} stroke-width={1.9} />
          </a>
          <a class="icon-button" href={profile.githubUrl} aria-label="Open GitHub profile" title="GitHub">
            <BrandIcon icon={faGithub} size={18} />
          </a>
          <a class="icon-button" href={profile.linkedInUrl} aria-label="Open LinkedIn profile" title="LinkedIn">
            <BrandIcon icon={faLinkedinIn} size={18} />
          </a>
        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <p>&copy; {new Date().getFullYear()} {profile.fullName}</p>
    <a href="#top">Back to top</a>
  </footer>

</BaseLayout>
